POSTGRES_DB=techsin
POSTGRES_USER=techsin
POSTGRES_PASSWORD=troque-esta-senha

PUBLIC_URL=https://seu-dominio.com
WEB_PORT=80

# ── E-mail (Resend) ─────────────────────────────────────────────
# API key do Resend (https://resend.com)
RESEND_API_KEY=

# Endereço técnico usado no campo From: (domínio deve estar verificado no Resend).
# O display name antes do "<>" é injetado em runtime a partir do campo
# `email_remetente` da transportadora (white-label por cliente).
EMAIL_FROM_ADDRESS=cobranca@techsin.site

# Nome usado no remetente quando a transportadora não tem `email_remetente` configurado.
EMAIL_FALLBACK_BRAND=TechSin
